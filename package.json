{
  "name": "mood-ai-backend",
  "version": "1.0.0",
  "description": "Mood-based AI personal assistant backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start-sql": "node server_sql.js",
    "dev": "nodemon server.js",
    "dev-sql": "nodemon server_sql.js",
    "test": "jest",
    "start-all": "./start-all.sh",
    "start-all-sql": "npm run start-sql",
    "dev-all": "concurrently \"npm run start-mongo\" \"npm run start-backend\" \"npm run start-frontend\"",
    "dev-all-sql": "concurrently \"npm run start-sql\" \"npm run start-frontend\"",
    "setup": "npm install && cd frontend && npm install",
    "start-backend": "node server.js",
    "start-backend-sql": "node server_sql.js",
    "start-frontend": "cd frontend && npm start",
    "start-mongo": "mkdir -p /tmp/mongodb && mongod --dbpath /tmp/mongodb --logpath /tmp/mongodb.log"
  },
  "keywords": [
    "mood",
    "ai",
    "personal-assistant",
    "jwt",
    "mongodb"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "argon2": "^0.31.1",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "natural": "^6.12.0",
    "pg": "^8.16.3",
    "sentiment": "^5.0.2",
    "sequelize": "^6.37.7",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
